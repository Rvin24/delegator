# ---------------------------------------------------------------------------
# .env.example — copy to .env (and chmod 600) for local development.
# Never commit a real .env. Never paste private keys into chat or version
# control.
# ---------------------------------------------------------------------------

# Chain selection.
#
# Easiest: set a preset name (case-insensitive). Available presets:
#   base, ethereum, arbitrum, optimism, polygon, bsc, ink,
#   sepolia, base-sepolia
#
# Default if unset: base (preserves the original behavior).
CHAIN=base

# Optional RPC override. If unset, the preset's default public RPC is used.
# Public RPCs are fine for occasional runs but are load-balanced and rate
# limited; for production-grade reliability point this at your own provider
# (Alchemy / Infura / QuickNode / etc.).
#RPC_URL=https://mainnet.base.org

# Custom chain (only when CHAIN is unset and the chain you want is not in
# the preset list). When using these, RPC_URL is REQUIRED.
#CHAIN_ID=
#RPC_URL=

# Backwards compatibility: BASE_RPC_URL is still honored as an alias for
# RPC_URL when CHAIN=base or unset.
#BASE_RPC_URL=https://mainnet.base.org

# Private key of the COMPROMISED wallet whose EIP-7702 delegation you want to
# re-point. Used ONLY to sign the SetCode authorization. The PK never moves
# any funds directly; it cannot since the wallet has no native gas balance.
COMPROMISED_PK=0x...

# Private key of a clean OPERATOR wallet on the selected chain with a few
# cents of native gas. Pays gas for the type-0x04 transaction that carries
# the authorization.
OPERATOR_PK=0x...

# Address that the EOA should be delegated to AFTER this run.
#
# Common choices:
#   - 0x0000000000000000000000000000000000000000  (clears delegation entirely;
#     EOA goes back to having empty code, like a fresh EOA)
#   - 0xYourMonthlyRescuer  (delegates to your own contract — anything sent to
#     the EOA is auto-handled by your contract's logic, e.g. forwarded to a
#     safe wallet)
#   - <any other contract you control>
DELEGATE_TARGET=0x...
